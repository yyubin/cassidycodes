flowchart TB
    START["엔티티 처리 시작<br/>(컴파일 라운드)"]

    subgraph ROUND["Round 처리 (순서 비보장)"]
        PROC["TypeElement 분석"]
        DEP{"의존 엔티티<br/>준비됨?<br/>(부모 PK / FK 대상)"}
        QUEUE["deferredEntities 큐에 추가"]
        NORMAL["정상 처리 완료"]
    end

    subgraph FINAL["최종 라운드 (processingOver = true)"]
        RETRY["재처리 시도<br/>maxPass = max(20, entityCount x 2)"]
        PROG{"이번 패스에서<br/>처리된 엔티티 있음?"}
        NOPR["noProgressCount++"]
        RESET["noProgressCount = 0"]
        DEAD{"3회 연속<br/>진전 없음?"}
        ERR["순환 의존성 감지<br/>Messager ERROR 출력"]
        DONE["처리 완료"]
    end

    START --> PROC
    PROC --> DEP
    DEP -->|"No - 아직 미처리"| QUEUE
    DEP -->|Yes| NORMAL
    QUEUE --> FINAL
    NORMAL --> FINAL

    RETRY --> PROG
    PROG -->|No| NOPR
    PROG -->|Yes| RESET
    NOPR --> DEAD
    DEAD -->|Yes| ERR
    DEAD -->|No| RETRY
    RESET --> RETRY
    RETRY -->|"deferredEntities 비어있음"| DONE

    style ROUND fill:#e3f2fd
    style FINAL fill:#fff3e0
    style ERR fill:#ffcdd2
    style DONE fill:#c8e6c9,color:#000
    style QUEUE fill:#ffcc80,color:#000
